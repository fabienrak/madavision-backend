# ────────────────────────────────────────────────────────────
#  AIRTABLE
# ────────────────────────────────────────────────────────────
AIRTABLE_PAT=patXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
AIRTABLE_BASE=appXXXXXXXXXXXXXX

# ────────────────────────────────────────────────────────────
#  SERVEUR
# ────────────────────────────────────────────────────────────
PORT=3001
# Origines autorisées (séparées par virgule, ou * pour tout autoriser)
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:5500
DEBUG=false

# ────────────────────────────────────────────────────────────
#  EMAIL — GMAIL (recommandé)
# ────────────────────────────────────────────────────────────
EMAIL_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# ⚠ IMPORTANT : utilisez un App Password Gmail, PAS votre mot de passe normal
# Activer la validation 2 étapes d'abord, puis :
# → https://myaccount.google.com/apppasswords
# → Créer une app "Madavision FIM" → copier les 16 caractères
SMTP_USER=votrecompte@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx    # Les espaces sont ignorés automatiquement

# L'adresse "from" doit être identique à SMTP_USER pour Gmail
EMAIL_FROM_NAME=Madavision FIM 2026
EMAIL_FROM_ADDRESS=votrecompte@gmail.com
EMAIL_BCC=

# ────────────────────────────────────────────────────────────
#  EMAIL — OVH (alternative)
# ────────────────────────────────────────────────────────────
# SMTP_HOST=ssl0.ovh.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=contact@madavision.mg
# SMTP_PASS=VotreMotDePasseOVH
# EMAIL_FROM_ADDRESS=contact@madavision.mg
